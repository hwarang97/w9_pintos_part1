{
    "name": "pintos-dev",
    "dockerFile": "Dockerfile",
    "remoteUser": "jungle",
    "remoteEnv": {
        "PATH": "${containerWorkspaceFolder}/pintos/utils:${containerEnv:PATH}"
    },
    "postCreateCommand": "bash -lc \"grep -qxF 'source ${containerWorkspaceFolder}/pintos/activate' ~/.bashrc || echo 'source ${containerWorkspaceFolder}/pintos/activate' >> ~/.bashrc\"",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cpptools",
                "ms-azuretools.vscode-docker",
                "ms-vscode.makefile-tools"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    }
}
